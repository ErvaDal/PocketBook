<?xml version="1.0" encoding="utf-8"?>
<!-- kayıt ol kısımı -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="32dp"
    android:paddingRight="32dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:background="@color/screen_background">

    <FrameLayout
        android:id="@+id/fl_theme_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_theme_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="Tema Değiştirici"
            android:src="@drawable/ic_moon"
            app:tint="@color/icon_tint" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/ll_register_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zaten üye misin? "
            android:textSize="16sp"
            android:textColor="@color/hint_color" />

        <TextView
            android:id="@+id/btn_register_login_redirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giriş Yap"
            android:textSize="16sp"
            android:textColor="@color/primary_color"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/fl_theme_container"
        app:layout_constraintBottom_toTopOf="@id/ll_register_footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_register_logo"
                android:layout_width="130dp"
                android:layout_height="90dp"
                android:src="@drawable/beyaz_logo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_register_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:letterSpacing="0.02"
                android:text="Papirus dünyasına katıl"
                android:textColor="@color/hint_color"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_register_logo" />

            <TextView
                android:id="@+id/tv_Label_Username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Kullanıcı Adı"
                android:textColor="@color/text_color_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_register_subtitle" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_Username"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/icon_tint"
                app:layout_constraintTop_toBottomOf="@id/tv_Label_Username">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_Username"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_background"
                    android:hint="papirus_kullanicisi"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/text_color_primary"
                    android:inputType="text"
                    android:paddingStart="48dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_Label_Email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Email"
                android:textColor="@color/text_color_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/til_Username" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_Email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/icon_tint"
                app:layout_constraintTop_toBottomOf="@id/tv_Label_Email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_Email"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_background"
                    android:hint="ornek@papirus.com"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/text_color_primary"
                    android:inputType="textEmailAddress"
                    android:paddingStart="48dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_Label_BirthDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Doğum Tarihi"
                android:textColor="@color/text_color_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/til_Email" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_BirthDate"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:startIconTint="@color/icon_tint"
                app:layout_constraintTop_toBottomOf="@id/tv_Label_BirthDate">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_BirthDate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_background"
                    android:hint="GG/AA/YYYY"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/text_color_primary"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:paddingStart="48dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_Label_PasswordHash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Şifre"
                android:textColor="@color/text_color_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/til_BirthDate" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_PasswordHash"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/icon_tint"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/icon_tint"
                app:layout_constraintTop_toBottomOf="@id/tv_Label_PasswordHash">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_PasswordHash"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_background"
                    android:hint="••••••••"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/text_color_primary"
                    android:inputType="textPassword"
                    android:paddingStart="48dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_Label_PasswordConfirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Şifre (Tekrar)"
                android:textColor="@color/text_color_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/til_PasswordHash" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_PasswordConfirm"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/icon_tint"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/icon_tint"
                app:layout_constraintTop_toBottomOf="@id/tv_Label_PasswordConfirm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_PasswordConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_background"
                    android:hint="••••••••"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/text_color_primary"
                    android:inputType="textPassword"
                    android:paddingStart="48dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register_submit"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/primary_color"
                android:text="Hesap Oluştur"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:cornerRadius="28dp"
                app:layout_constraintTop_toBottomOf="@id/til_PasswordConfirm"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>