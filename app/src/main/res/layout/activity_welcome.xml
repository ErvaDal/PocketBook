<?xml version="1.0" encoding="utf-8"?>
<!--ilk kayıt ol, giriş yap kısımı-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    android:background="@color/screen_background">

    <FrameLayout
        android:id="@+id/fl_theme_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_theme_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_moon"
            app:tint="@color/icon_tint" />
    </FrameLayout>

    <ImageView
        android:id="@+id/iv_welcome_logo"
        android:layout_width="220dp"
        android:layout_height="160dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/beyaz_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fl_theme_container" />

    <TextView
        android:id="@+id/tv_welcome_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Papirus dünyasına hoş geldin"
        android:textColor="@color/hint_color"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_welcome_logo" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_welcome_login"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="48dp"
        android:backgroundTint="@color/primary_color"
        android:text="Giriş Yap"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome_subtitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_welcome_register"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/primary_color"
        android:text="Kayıt Ol"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/btn_welcome_login" />

</androidx.constraintlayout.widget.ConstraintLayout>