<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="16dp"
    android:paddingHorizontal="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_chapter_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bölüm Adı"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_color_primary"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_chapter_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yayınlandı"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"/>

            <TextView
                android:id="@+id/tv_chapter_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="👁 4.5K  |  ❤️ 1.2K  |  💬 84"
                android:textSize="12sp"
                android:textColor="@color/hint_color"/>
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_chapter_options"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_more"
        app:tint="@color/hint_color"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>